# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# Patterns are intentionally unanchored (no leading slash) so they match inside
# every workspace — apps/web, apps/api, packages/* — not just the repo root.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# contracts (hardhat)
artifacts/
cache/
typechain-types/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — every real env stays out, but the blank-valued template is
# committed on purpose so a fresh clone knows which keys to set.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# compiled output — regenerated by every build, including Railway's
# (`npm run build --workspace @float/api`). Tracking it meant CI typechecked
# the web app against a stale copy of the API's .d.ts files and failed on
# symbols that existed in source.
dist/

# Strategy + product docs — not for the public repo
/internal/

# playwright
test-results/
playwright-report/
