{
  "name": "@float/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "FLOAT contracts \u2014 LeashManager + PledgeVault on Arbitrum",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network arbitrumOne",
    "typecheck": "hardhat compile && tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "dotenv": "^17.2.4",
    "hardhat": "^2.28.6"
  }
}
