{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build --workspace @float/indexer"
  },
  "deploy": {
    "startCommand": "node packages/indexer/dist/index.js",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
