# FLOAT — environment template. Copy to .env.local and fill in.
# Every key present, every value blank. Never commit real values.
#
# Scoping: NEXT_PUBLIC_* is exposed to the browser and must contain nothing
# secret. Everything else is server-only (apps/api, packages/indexer,
# packages/contracts) and must never gain a NEXT_PUBLIC_ prefix.

# ─────────────────────────────────────────────────────────────
# Web (apps/web)
# ─────────────────────────────────────────────────────────────

# Canonical origin, used as metadataBase so og:image/twitter:image resolve to
# absolute URLs. Optional — falls back to the Vercel deployment URL, then to
# http://localhost:3000. Set once a custom domain is chosen.
NEXT_PUBLIC_SITE_URL=

# Base URL of the API in apps/api (Railway). Also carries the Particle RPC
# proxy at /particle, so this must be set for sends to work on networks that
# can't reach Particle directly.
NEXT_PUBLIC_API_URL=

# Browser-side Arbitrum One RPC — the chain Magic signs and sends on.
# Optional; defaults to Arbitrum's public endpoint (https://arb1.arbitrum.io/rpc).
# Set to a dedicated provider if the public node rate-limits.
NEXT_PUBLIC_ARBITRUM_RPC_URL=

# ─────────────────────────────────────────────────────────────
# Chain / accounts
# ─────────────────────────────────────────────────────────────

# Particle Network Universal Accounts (EIP-7702 mode).
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Particle server key — server-side only, never in the browser bundle.
PARTICLE_SERVER_KEY=

# Magic Labs. Publishable key is browser-safe; the secret key signs server-side
# and must stay server-only.
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=
MAGIC_SECRET_KEY=

# WalletConnect, for upgrading an existing EOA in place via EIP-7702.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Arbitrum RPC. Sepolia for the working build; One for mainnet.
# See AGENT_PROGRESS.md open question 6 (provider undecided).
ARBITRUM_SEPOLIA_RPC_URL=
ARBITRUM_ONE_RPC_URL=
NEXT_PUBLIC_ARBITRUM_CHAIN_ID=

# ─────────────────────────────────────────────────────────────
# Database (Supabase)
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key bypasses RLS. Server-only, never in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref + database password, used by the Supabase CLI for migrations
# (packages/db). The password is shown once at project creation.
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Direct Postgres connection string, for the indexer and any raw SQL.
SUPABASE_DB_URL=

# NOT REQUIRED. The project signs with asymmetric ECC P-256 keys, so sessions
# are minted by Supabase itself (auth.admin.generateLink + verifyOtp) rather
# than hand-signed. Verified by `npm run verify:session -w @float/db`.
# The legacy HS256 shared secret is verify-only and will be revoked.
# SUPABASE_JWT_SECRET=

# ─────────────────────────────────────────────────────────────
# Contracts (packages/contracts)
# ─────────────────────────────────────────────────────────────

# Deployer private key. Use a throwaway key funded only for deployment.
DEPLOYER_PRIVATE_KEY=

# Arbiscan verification.
ARBISCAN_API_KEY=

# Deployed addresses — fill in after Phase 2 ships.
NEXT_PUBLIC_LEASH_MANAGER_ADDRESS=
NEXT_PUBLIC_PLEDGE_VAULT_ADDRESS=

# Pledge failure destinations. Blocked: the frontend carries labels only, no
# addresses. See AGENT_PROGRESS.md open question 1.
PLEDGE_DESTINATION_GITCOIN_ADDRESS=
PLEDGE_DESTINATION_DAO_ADDRESS=
PLEDGE_DESTINATION_BURN_ADDRESS=

# ─────────────────────────────────────────────────────────────
# Identity resolution
# ─────────────────────────────────────────────────────────────

# ENS resolution runs through the Arbitrum/mainnet RPC above.
# Farcaster: Neynar vs Hubble undecided — see open question 5.
NEYNAR_API_KEY=

# ─────────────────────────────────────────────────────────────
# Indexer (packages/indexer)
# ─────────────────────────────────────────────────────────────

# Block to begin backfill from — set to the contract deployment block.
INDEXER_START_BLOCK=

# ─────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────

# Transactional email for claim links and witness prompts. Provider TBD.
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# Signing secret for scoped, expiring share/claim/settle link tokens.
LINK_TOKEN_SECRET=
